FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (1 0 0); // Entrada en la dirección +X
    }
    
    // NOTA: 'outlets' será el nombre que le demos al grupo de las 5 salidas
    outlets
    {
        type            zeroGradient;
    }
    
    walls
    {
        type            noSlip;
    }
}
